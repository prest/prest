# Copy to .env and set your database URL (docker compose reads this file).
# Never commit .env — it may contain credentials.

# Example remote (append ?sslmode=require for AWS RDS / Heroku):
# PREST_PG_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Example local compose Postgres (--profile local):
# PREST_PG_URL=postgres://postgres:postgres@postgres:5432/prest?sslmode=disable

PREST_PG_URL=
